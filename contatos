##################### ADD #####################
def adicionar_contato(name,namespace,ip,port):
    contatos = carregar_json()
    repetido = False
    for c in contatos:
        if c["Name"] == name and c["@"] == namespace:
            repetido = True
            c["IP"] = ip
            c["Port"] = port
        
        if c["IP"] == ip and int(c["Port"]) == int(port): #que odio
            repetido = True
            c["Name"] = name
            c["@"] = namespace
    
    if not repetido:
        novo = {
            "Name": name,
            "@": namespace,
            "IP": ip,
            "Port": str(port),       
            "Active": "False",
            "RTT": [],
            "PONG": 0
        }

        contatos.append(novo)

    with open(contatos_json, 'w', encoding='utf-8') as arquivo:
        json.dump(contatos, arquivo, indent=4)
        
    return contatos

        
##################### REMOVE #####################
def remover_contato(name, namespace):
    contatos = carregar_json()
    contatos_restantes = [
        c for c in contatos 
        if not (c["Name"] == name and c["@"] == namespace)
    ]
    if len(contatos_restantes) < len(contatos):
        print(f"\n -> Contato {name}@{namespace} removido com sucesso!")
    else:
        print(f"\n -> Contato {name}@{namespace} não encontrado.")

    # Salva a lista atualizada de volta no arquivo
    with open(contatos_json, 'w', encoding='utf-8') as arquivo:
        json.dump(contatos_restantes, arquivo, indent=4)


       
