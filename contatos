##################### PROCURA #####################
def procura_contato(dst):
    contatos = carregar_json()
    ip = 0
    port = 0
    name, namespace = dst.split('@')
    for c in contatos:
        if c["Name"] == name and c["@"] == namespace:
            ip = c["IP"]
            port = c["Port"]
            
    if ip == 0:
        print(f"Não achei o {dst} nos contatos, tente novamente...")
        
    return ip, port


##################### PROCURA IP #####################
def resolver_ip(ip, port):
    contatos = carregar_json()
    name = ""
    namespace = ""
    for c in contatos:
        if c["IP"] == ip and int(c["Port"]) == int(port):
            name = c["Name"]
            namespace = c["@"]
            
    if name == "":
        print("Não achei (resolver_ip)")
        return None
        
    dst = f"{name}@{namespace}"  
    return dst
    


